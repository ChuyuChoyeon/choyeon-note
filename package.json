{
  "name": "choyeon-note",
  "version": "2.0.1",
  "description": "Choyeon Note - A beautiful acrylic design note-taking application",
  "main": "electron/main.js",
  "author": "Choyeon",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5176 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "generate:icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "katex": "^0.18.1",
    "lucide-vue-next": "^0.298.0",
    "marked": "^11.1.0",
    "mermaid": "^11.16.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^43.1.1",
    "electron-builder": "^24.13.3",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.2",
    "postcss": "^8.4.32",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.choyeon.note",
    "productName": "Choyeon Note",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "ChuyuChoyeon",
      "repo": "choyeon-note"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico"
    }
  }
}
